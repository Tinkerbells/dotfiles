#!/bin/bash
output='/home/$USER/Pictures/screenshots/%Y-%m-%d-%T-screenshot.png'

case "$1" in
  "select") scrot "$output" --select --line mode=edge || exit ;;
  "window") scrot "$output" --focused --border || exit ;;
  *) scrot "$output" || exit ;;
esac

dunstify -I "$(date +$output)" "Screenshot taken"
