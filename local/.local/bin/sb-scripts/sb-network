#!/bin/bash

update() {
  R1=$(cat /sys/class/net/wlp0s20f3/statistics/rx_bytes)
  sleep 1
  R2=$(cat /sys/class/net/wlp0s20f3/statistics/rx_bytes)
  RBPS=$(expr $R2 - $R1)
  RKBPS=$(expr $RBPS / 125000)
  echo "$RKBPS"
}

speed=$(update)

echo "’øÖ $speed Mbit/s"

case $BLOCK_BUTTON in
  1) dunstify -r 942 -t 3000 -i network-speed "$(speedtest --simple)" ;;
esac
