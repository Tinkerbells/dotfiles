#!/bin/bash
provider_max_speed=250 # Change to your max provider network speed

get_speed() {
  mullvad status | grep Disconnected && iface="wlp0s20f3" || iface="wg-mullvad"
  new=$(cat /sys/class/net/$iface/statistics/rx_bytes)
  cache=/tmp/$iface
  [ -f "$cache" ] && read -r old < "$cache" || old=0
  echo "$new" > "$cache"
  dif=$(expr $new - $old)
  mbits=$(expr $dif / 131072)
  echo "$mbits"
}

speed=$(get_speed)

if (($(echo "$speed > $provider_max_speed*0.8" | bc -l))); then
  color="^c#8aadf4^"
elif (($(echo "$speed > $provider_max_speed*0.5" | bc -l))); then
  color="^c#eed49f^"
elif [[ "$speed" -eq "0" ]];then
  color=""
else 
  color="^c#ed8796^"
fi

echo "$color $speed MBit/s^d^"

case $BLOCK_BUTTON in
	1) dunstify -u low -r 942 -t 6000 -i network-speed "$(speedtest --simple)" ;;
esac
