#!/bin/sh

status=$(sleep 10 && nmcli dev status | awk '{print $3;}' | sed -n '2 p')

if [ "$status" != "disconnected" ]; then
  price=$(curl -sS "https://free.currconv.com/api/v7/convert?q=USD_RUB&compact=ultra&apiKey=3100dea3775f17212859" | jq .USD_RUB)
  printf ' %.*f' 2 $price
else
  printf "disconnected"
fi

case $BLOCK_BUTTON in
  1) alacritty --hold -e tstock -b 24 -t 60min usd/rub ;;
esac
