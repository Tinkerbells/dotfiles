#!/bin/sh

path="/home/$USER/.local/bin/sb-scripts/dollar-price"
status=$(nmcli dev status | awk '{print $3;}' | sed -n '2 p')
update_time=$(date "+%m-%d-%Y, %H:%m:%S")
old_price=$(cat $path | head -n 1)

if [ "$status" != "disconnected" ]; then
  price=$(curl -sS "https://free.currconv.com/api/v7/convert?q=USD_RUB&compact=ultra&apiKey=3100dea3775f17212859" | jq .USD_RUB)
  if (($(echo "$price > $old_price" | bc -l))); then
    icon="’ĢØ"
  else
    icon="’Ģģ"
  fi
  printf "’ģĢ %.*f $icon" 2 $price && rm -rf $path && echo -e "$price\nUpdate time - $update_time" > $path
else
  printf "’ģĢ %.*f" 2 $old_price
fi

case $BLOCK_BUTTON in
  1) alacritty --hold -e tstock -b 24 -t 60min usd/rub ;;
esac
