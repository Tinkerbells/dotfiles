#!/bin/sh

status=$(sleep 10 && nmcli dev status | awk '{print $3;}' | sed -n '2 p')
old_price=$(cat $HOME/.cache/dollar | head -n 1)

if [ "$status" != "disconnected" ]; then
    price=$(printf "%.*f" 2 $(curl -sS "https://free.currconv.com/api/v7/convert?q=USD_RUB&compact=ultra&apiKey=3100dea3775f17212859" | jq .USD_RUB))
    if (($(echo "$price > $old_price" | bc -l))); then
        icon="^c#ed8796^ď•ť"
        change=$(printf "%.*f" 2 $(echo "100-$old_price/$price*100" | bc -l))
    else
        icon="^c#a6da95^ď•…"
        change=$(printf "%.*f" 2 $(echo "100-$price/$old_price*100" | bc -l))
    fi
    echo "^b#494d64^^c#cad3f5^ ď…• $price $icon $change% ^d^"
else
    echo "^b#494d64^^c#cad3f5^ ď…• $old_price ^d^"
fi

case $BLOCK_BUTTON in
    1) alacritty --hold -e tstock -b 24 -t 60min usd/rub ;;
esac
