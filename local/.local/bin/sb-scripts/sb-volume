#!/bin/sh

[ $(pamixer --get-mute) = true ] && echo " muted" && exit

volume="$(pamixer --get-volume)"

if [ "$volume" -gt "80" ]; then
  icon=""
elif [ "$volume" -gt "50" ]; then
  icon="墳"
elif [ "$volume" -gt "10" ]; then
  icon=""
else
  icon="" && exit
fi

echo "[ $icon $volume% ]"

case $BLOCK_BUTTON in
  1) pavucontrol ;;
esac
