#!/bin/sh

[ $(pamixer --get-mute) = true ] && echo "^b#363a4f^^c#ed8796^  muted ^d^" && exit

volume="$(pamixer --get-volume)"

if [ "$volume" -ge "80" ]; then
    icon=""
elif [ "$volume" -gt "50" ]; then
    icon="墳"
elif [ "$volume" -gt "10" ]; then
    icon=""
else
    icon=""
fi

echo "^b#363a4f^^c#cad3f5^ $icon $volume% ^d^"

case $BLOCK_BUTTON in
    1) pavucontrol ;;
esac
