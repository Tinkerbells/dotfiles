#!/bin/sh

[ $(pamixer --get-mute) = true ] && echo "^c#ed8796^’æ”^d^ muted" && exit

volume="$(pamixer --get-volume)"

if [ "$volume" -ge "80" ]; then
  icon="^c#eed49f^’Ć©"
elif [ "$volume" -gt "50" ]; then
  icon="^c#a6da95^’®Į"
elif [ "$volume" -gt "10" ]; then
  icon="^c#8aadf4^’Ć¦"
else
  icon="’Ć”"
fi

echo "$icon $volume%^d^"

case $BLOCK_BUTTON in
  1)pamixer -i 5 && dunstify -a "changevolume" -u low -r "9993" -h "$volume" -i "volume-up"  "Volume: ${volume}%" -t 2000 ;;
  2) pavucontrol ;;
  3)pamixer -d 5 && dunstify -a "changevolume" -u low -r "9993" -h "$volume" -i "volume-down" "Volume: ${volume}%" -t 2000 ;;
esac
