#!/bin/sh

pidof -x sb-mpdup > /dev/null 2>&1 || sb-mpdup > /dev/null 2>&1 &

if [ $(mpc | wc -l) -lt 3 ];then
 name="empty list"
else
 name=$(mpc | head -n 1)
fi

mpc | grep paused > /dev/null 2>&1 && echo "[  ${name:0:30} " ] || echo "[  ${name:0:30} ]" 

case $BLOCK_BUTTON in
  1) mpc next;;
  2) mpc | grep paused && mpc play || mpc pause ;;
  3) mpc prev;;
esac
