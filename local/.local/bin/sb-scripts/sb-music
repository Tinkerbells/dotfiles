#!/bin/sh

pidof -x sb-mpdup > /dev/null 2>&1 || sb-mpdup > /dev/null 2>&1 &

if [ $(mpc | wc -l) -lt 3 ];then
    echo "empty playlist" && exit
else
    name=$(mpc | head -n 1 | cut -c1-45)
fi

mpc | grep paused > /dev/null 2>&1 && echo "^b#494d64^^c#cad3f5^ ягг $name ^d^"  || echo "^b#494d64^^c#cad3f5^ ядЙ $name ^d^"

case $BLOCK_BUTTON in
    1) mpc next ;;
    2) mpc | grep paused && mpc play || mpc pause ;;
    3) mpc prev ;;
esac
