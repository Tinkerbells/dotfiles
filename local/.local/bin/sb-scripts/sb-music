#!/bin/sh

get_name() {
  echo "$(mpc | sed "/^volume:/d;s/\\&/&amp;/g;s/\\[paused\\].*//g;/\\[playing\\].*/d;/^ERROR/Q" | paste -sd ' ' -)"
}

pidof -x sb-mpdup > /dev/null 2>&1 || sb-mpdup > /dev/null 2>&1 &

name=$(get_name)

echo " $name"

case $BLOCK_BUTTON in
  1)
    setsid -f "$TERMINAL" -e ncmpcpp
    ;; # right click, pause/unpause
esac
