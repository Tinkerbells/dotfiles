#!/bin/bash

status=$(nmcli dev status | awk '{print $3;}' | sed -n '2 p')
name=$(nmcli dev status | awk '{print $4;}' | sed -n '2 p')

if [ "$status" != "disconnected" ]; then
  echo "^c#a6da95^直 $name^d^"
else
  echo "^c#ed8796^睊 disconnected^d^"
fi

case $BLOCK_BUTTON in
  1) alacritty -e nmtui ;;
esac
