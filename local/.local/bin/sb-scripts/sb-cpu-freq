#!/bin/bash

freq=$(cat /proc/cpuinfo | grep MHz | grep -oE '[^ ]+$' | tr "\n" " ")

cores=8

sum=0

for f in $freq; do
    sum=$(echo "$sum + $f" | bc -l)
done;

result=$(printf "%.*f" 1 $(echo "$sum / $cores / 1000" | bc -l))

if (($(echo "$result > 2" | bc -l))); then
    color="^c#ed8796^"
fi

echo "^b#494d64^ $colorď§„ $result GHz ^d^"
