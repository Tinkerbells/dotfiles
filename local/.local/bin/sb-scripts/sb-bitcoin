#!/bin/sh

path="/home/$USER/.cache/bitcoin"
status=$(sleep 10 && nmcli dev status | awk '{print $3;}' | sed -n '2 p')
old_price=$(cat $path | head -n 1)

if [ "$status" != "disconnected" ]; then
  price=$(curl -sS "https://rest.coinapi.io/v1/exchangerate/BTC/USD?apikey=7F390A8F-EAE9-4FB4-9F15-363124425D0F" | jq .rate)

  if (($(echo "$price > $old_price" | bc -l))); then
    icon="ď•ť"
    change=$(echo "100-$old_price/$price*100" | bc -l)
  else
    icon="ď•…"
    change=$(echo "100-$price/$old_price*100" | bc -l)
  fi
  printf "[ ď…š %.*f $icon %.*f%% ]" 2 $price 2 $change
else
  printf "[ ď…š %.*f ]" 2 $old_price
fi

case $BLOCK_BUTTON in
  1) alacritty --hold -e tstock -b 24 -t 60min btc ;;
esac
