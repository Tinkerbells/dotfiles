ACTION=="change", SUBSYSTEM=="power_supply", ATTR{status}=="Charging", RUN+="/usr/bin/su tinkerbells -c /home/tinkerbells/.local/bin/bt-charging-notify"
ACTION=="change", SUBSYSTEM=="power_supply", ATTR{status}=="Discharging", RUN+="/usr/bin/su tinkerbells -c /home/tinkerbells/.local/bin/bt-discharging-notify"
