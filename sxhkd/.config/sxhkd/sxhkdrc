# Running apps
super + w  
  brave 

super +  t 
  telegram-desktop

super + Return 
  alacritty -t terminal

super + r 
  rofi -show drun

super + shift + f 
  nemo

# Running terminal based apps
super + f 
  alacritty -t lf -e lfub 

super + m 
  alacritty -t ncmpcpp -e ncmpcpp

# Dunstctl histroy bind
alt + h
  dunstctl history-pop                              
  
# Media Control keys
XF86AudioLowerVolume
  change-volume down	

XF86AudioRaiseVolume
  change-volume up 
  
XF86AudioMute
  change-volume mute 

XF86AudioPlay
  mpc toggle 

XF86AudioStop
  mpc stop 

XF86AudioNext
  mpc next

XF86AudioPrev
  mpc prev

XF86MonBrightnessUp
  change-brightness up

XF86MonBrightnessDown
  change-brightness down 

alt + o 
  change-audio-sink

alt + n
  mpc next

alt + p
  mpc prev

alt + Return
  mpc {pause,play}

# Change keyboard layout
alt + Shift_L 
  change-keyboard-layout

# Screenshot
super + shift + s
  screenshot select  
super + s
  screenshot 
super + control + shift + s
  screenshot window

# Clipmanager 
super + c 
  rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# Calculator  
alt + c 
  rofi -show calc -modi calc -no-show-match -no-sort -calc-command "echo -n '{result}' | xclip"

# Color picker
alt + e 
  farge --no-preview

# Suspend
super + shift + l 
  systemctl suspend
  
# Custom scripts 
alt + t
  notify-time
