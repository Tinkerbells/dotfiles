# Running apps
super + w  
  brave 

super + shift + t 
  telegram-desktop

super + Return 
  alacritty

super + r 
  rofi -show drun

super + shift + f 
  nemo

# Running terminal based apps
super + shift + v
  alacritty -t lvim -e lvim 

super + f 
  alacritty -t lf -e lfub 

super + m 
  alacritty -t ncmpcpp -e ncmpcpp

# Media Control keys
XF86AudioLowerVolume
  change-volume down	

XF86AudioRaiseVolume
  change-volume up 
  
XF86AudioMute
  change-volume mute 

XF86MonBrightnessUp
  change-brightness up

XF86MonBrightnessDown
  change-brightness down 

# Change keyboard layout
alt + Shift_L 
  change-keyboard-layout

# Screenshot
super + shift + s
  screenshot select  
super + s
  screenshot 
super + control + shift + s
  screenshot window

# Clipmanager 
super + c 
  rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}'

# Calculator  
alt + c 
  rofi -show calc -modi calc -no-show-match -no-sort -calc-command "echo -n '{result}' | xclip"

# Bitwarden 
super + x 
  bwmenu

# Suspend
super + shift + l 
  systemctl suspend
